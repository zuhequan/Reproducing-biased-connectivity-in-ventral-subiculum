





import pandas as pd
import plotly.express as px
import plotly.graph_objects as go





df_vS = pd.read_csv("data/coronal_CTBLabelled_dataset.csv")
df_vS.head(5)

# Filter dataframe by projection type
df_subset_PFC = df_vS[df_vS.Projection == "PFC"]
df_subset_NAc = df_vS[df_vS.Projection == "NAc"]
df_subset_LH = df_vS[df_vS.Projection == "LH"]

# set colors and styles for vS neuron subsets
PFC_color = "#FFDB6E"
NAc_color = "#BF43CC"
LH_color = "#87FFE1"

opacity = 0.7
size = 2

# add plot
fig = px.scatter_3d(df_subset_PFC, x="AP", y="ML", z="DV", opacity=opacity)

fig.update_traces(marker=dict(size=size, color=PFC_color), name="PFC", showlegend=True)

fig.add_trace(
    go.Scatter3d(
        x=df_subset_NAc["AP"],
        y=df_subset_NAc["ML"],
        z=df_subset_NAc["DV"],
        opacity=opacity,
        mode="markers",
        marker=dict(size=size, color=NAc_color),
        name="NAc",
        showlegend=True,
    )
)

fig.add_trace(
    go.Scatter3d(
        x=df_subset_LH["AP"],
        y=df_subset_LH["ML"],
        z=df_subset_LH["DV"],
        opacity=opacity,
        mode="markers",
        marker=dict(size=size, color=LH_color),
        name="LH",
        showlegend=True, 
    )
)

fig.update_layout(width=1200, height=800, legend=dict(itemclick="toggle", itemdoubleclick="toggleothers", itemsizing='constant', x=0.5, y=0.5))

fig.update_scenes(aspectmode="data")

fig.show()





df_trio_PFC = pd.read_csv("data/PFC_TRIO_cellcounts.csv")
#df_trio_PFC.head(5)
df_trio_NAc = pd.read_csv("data/NAc_TRIO_cellcounts.csv")
df_trio_LH = pd.read_csv("data/LH_TRIO_cellcounts.csv")

# PFC_TRIO plot (indicating upstream brain areas)
fig = px.scatter_3d(df_trio_PFC, x="AP", y="ML", z="DV", opacity=0.5)

fig.update_traces(marker=dict(size=2, color=df_trio_PFC['color']))

fig.update_layout(width=1200, height=800, title=dict(text='PFC TRIO', x=0.5, y=0.8))
fig.update_scenes(aspectmode="data")
fig.show()


# comparing 3 groups of upstream cells (Fig 3B)
fig = px.scatter_3d(df_trio_PFC, x="AP", y="ML", z="DV", opacity=0.5)

fig.update_traces(marker=dict(size=2, color="#FFDB6E"), name="PFC", showlegend=True)

fig.add_trace(
    go.Scatter3d(
        x=df_trio_NAc["AP"],
        y=df_trio_NAc["ML"],
        z=df_trio_NAc["DV"],
        opacity=0.5,
        mode="markers",
        marker=dict(size=2, color="#BF43CC"),
        name="NAc",
        showlegend=True,
    )
)

fig.add_trace(
    go.Scatter3d(
        x=df_trio_LH["AP"],
        y=df_trio_LH["ML"],
        z=df_trio_LH["DV"],
        opacity=0.5,
        mode="markers",
        marker=dict(size=2, color="#87FFE1"),
        name="LH",
        showlegend=True, 
    )
)

fig.update_layout(width=1200, height=800, title=dict(text='All starter cells', x=0.5, y=0.8), legend=dict(itemclick="toggle", itemdoubleclick="toggleothers", itemsizing='constant', x=0.5, y=0.5))

fig.update_scenes(aspectmode="data")
fig.show()
